{
  "name": "@neoacar/claude-handoff",
  "version": "0.1.0",
  "description": "Make Claude Code session context portable between machines via git",
  "type": "module",
  "bin": {
    "claude-handoff": "./dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:fixtures": "vitest run --config vitest.config.ts test/fixtures",
    "lint": "prettier --check . && tsc --noEmit",
    "lint:fix": "prettier --write .",
    "prepublishOnly": "npm run build && npm test"
  },
  "engines": {
    "node": ">=20"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/NeoAcar/claude-handoff.git"
  },
  "bugs": {
    "url": "https://github.com/NeoAcar/claude-handoff/issues"
  },
  "homepage": "https://github.com/NeoAcar/claude-handoff#readme",
  "keywords": [
    "claude",
    "claude-code",
    "cli",
    "session",
    "handoff",
    "git",
    "portable",
    "context"
  ],
  "author": {
    "name": "Emin Acar",
    "email": "eminacar859@gmail.com",
    "url": "https://github.com/NeoAcar"
  },
  "license": "MIT",
  "dependencies": {
    "commander": "^13.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.15.3",
    "prettier": "^3.5.3",
    "typescript": "^5.8.3",
    "vitest": "^3.1.2"
  }
}
